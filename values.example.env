# Real values for rendering manifests before apply. COMMITTED as an EXAMPLE (placeholders only).
# Copy to values.local.env and fill real values. values.local.env is gitignored — never committed.
#
#   cp values.example.env values.local.env   # then edit values.local.env
#   bash render-and-apply.sh 04-configmap.yaml
#
# Keys map 1:1 to the <PLACEHOLDER> tokens in the yaml files.

YOUR_ACCOUNT_ID=000000000000
YOUR_DOMAIN=example.com
REGION=us-east-1
YOUR_CERT_ID=00000000-0000-0000-0000-000000000000
YOUR_WAF_ID=00000000-0000-0000-0000-000000000000
YOUR_ALLOWED_CIDRS=0.0.0.0/0
